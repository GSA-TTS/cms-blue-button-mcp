# Blue Button API Credentials
# Register your app at: https://sandbox.bluebutton.cms.gov/

BLUEBUTTON_CLIENT_ID=your_client_id_here
BLUEBUTTON_CLIENT_SECRET=your_client_secret_here

# Your MCP server's public URL (must match registered redirect URI)
BLUEBUTTON_BASE_URL=your_url_here

# Set to "false" for production Blue Button API
BLUEBUTTON_SANDBOX=true
